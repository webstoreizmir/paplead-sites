---
import { getSmartImage } from '../utils/images';

interface Stat {
  label: string;
  value: string;
}

interface Props {
  title: string;
  description: string;
  stats: Stat[];
  imageKeyword: string;
}

const { title, description, stats, imageKeyword } = Astro.props;
const imgUrl = getSmartImage(imageKeyword);
---

<section id="about" class="py-28 relative overflow-hidden bg-white">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-1/3 h-full opacity-3 pointer-events-none" style="background: radial-gradient(ellipse at top right, rgb(var(--color-primary)), transparent 70%)"></div>

  <div class="container-custom">
    <div class="flex flex-col lg:flex-row items-center gap-20">

      <!-- Image Column -->
      <div class="w-full lg:w-1/2 relative" data-animate>
        <!-- Decorative frame -->
        <div class="absolute -top-5 -left-5 w-full h-full rounded-3xl border-2 opacity-20 pointer-events-none" style="border-color: rgb(var(--color-primary))"></div>

        <div class="relative">
          <img
            src={imgUrl}
            alt={title}
            class="relative rounded-3xl shadow-2xl w-full object-cover h-[480px] lg:h-[560px]"
            loading="lazy"
          />

          <!-- Overlay badge -->
          <div class="absolute -bottom-6 -right-6 hidden lg:flex items-center gap-4 bg-white p-5 rounded-2xl shadow-2xl border border-slate-100">
            <div class="w-14 h-14 rounded-xl flex items-center justify-center bg-primary-gradient shadow-lg">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <div>
              <p class="text-2xl font-bold" style="color: rgb(var(--color-primary))">7/24</p>
              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Kesintisiz Hizmet</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Content Column -->
      <div class="w-full lg:w-1/2" data-animate data-animate-delay="200">
        <span class="section-label">Markamız</span>
        <h2 class="section-title mb-6">{title}</h2>

        <div class="relative pl-5 mb-10">
          <div class="absolute left-0 top-0 bottom-0 w-1 rounded-full" style="background: linear-gradient(to bottom, rgb(var(--color-primary)), rgb(var(--color-secondary)))"></div>
          <p class="text-lg text-slate-600 leading-relaxed">{description}</p>
        </div>

        {stats && stats.length > 0 && (
          <div class="grid grid-cols-2 gap-4 mb-10">
            {stats.map((stat, i) => (
              <div
                class="p-6 rounded-2xl border border-slate-100 hover:border-opacity-100 transition-all duration-300 hover:shadow-lg group"
                data-animate
                data-animate-delay={String((i + 1) * 100)}
              >
                <p
                  class="text-3xl font-bold mb-1 group-hover:scale-110 transition-transform origin-left"
                  style="color: rgb(var(--color-primary))"
                >
                  {stat.value}
                </p>
                <p class="text-sm font-medium text-slate-500">{stat.label}</p>
              </div>
            ))}
          </div>
        )}

        <a href="#contact" class="btn-primary inline-flex">
          Bizimle Çalışın
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
