---
import { getUI } from '../utils/i18n';
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
}

const { faqs, locale } = Astro.props;
const ui = getUI(locale);
---

<section id="faq" class="py-28 bg-slate-50 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-72 h-72 rounded-full blur-3xl opacity-5 pointer-events-none" style="background: rgb(var(--color-primary))"></div>

  <div class="container-custom max-w-4xl">
    <!-- Header -->
    <div class="text-center mb-16" data-animate>
      <span class="section-label">SSS</span>
      <h2 class="section-title mb-5">{ui.faq.title}</h2>
      <p class="section-subtitle">{ui.faq.subtitle}</p>
    </div>

    <!-- FAQ Items -->
    <div class="space-y-3">
      {faqs.map((faq, i) => (
        <details
          class="group bg-white rounded-2xl shadow-sm border border-slate-200/80 overflow-hidden hover:border-[rgb(var(--color-primary))]/30 hover:shadow-md transition-all duration-300"
          data-animate
          data-animate-delay={String(i * 80)}
        >
          <summary class="flex justify-between items-center cursor-pointer list-none p-7 select-none">
            <div class="flex items-center gap-4">
              <span class="text-xs font-bold w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0 text-white bg-primary-gradient">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="text-base md:text-lg font-bold text-slate-800 group-hover:text-[rgb(var(--color-primary))] transition-colors">
                {faq.question}
              </span>
            </div>
            <span class="faq-icon ml-4 flex-shrink-0 w-8 h-8 rounded-full border border-slate-200 flex items-center justify-center group-hover:border-[rgb(var(--color-primary))] group-hover:bg-[rgb(var(--color-primary))]/5 transition-all">
              <svg class="w-4 h-4 text-slate-400 group-hover:text-[rgb(var(--color-primary))] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
              </svg>
            </span>
          </summary>
          <div class="px-7 pb-7 pt-0">
            <div class="ml-11 text-slate-600 leading-relaxed border-t border-slate-100 pt-5">
              {faq.answer}
            </div>
          </div>
        </details>
      ))}
    </div>

    <!-- Still have questions -->
    <div class="mt-14 text-center" data-animate>
      <p class="text-slate-500 mb-5">Hâlâ sorunuz mu var?</p>
      <a href="#contact" class="btn-primary inline-flex">
        Bize Sorun
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
      </a>
    </div>
  </div>
</section>
