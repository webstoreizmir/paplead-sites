---
interface Testimonial {
  name: string;
  role: string;
  comment: string;
}

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;

const colors = ['from-purple-600 to-blue-600', 'from-emerald-500 to-teal-600', 'from-orange-500 to-rose-600', 'from-blue-500 to-indigo-600'];
---

<section id="testimonials" class="py-28 relative overflow-hidden" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%)">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.2) 1px, transparent 0); background-size: 36px 36px;"></div>
  <!-- Top gradient fade -->
  <div class="absolute top-0 left-0 right-0 h-24 bg-gradient-to-b from-white to-transparent pointer-events-none" style="opacity:0.03"></div>

  <div class="container-custom relative z-10">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-20" data-animate>
      <span class="section-label">Referanslar</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold text-white mb-4">Müşterilerimiz Ne Diyor?</h2>
      <p class="text-slate-400 text-lg">Gerçek müşterilerimizin deneyimlerini okuyun.</p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials.map((t, i) => (
        <div
          class="group relative bg-slate-800/60 backdrop-blur-sm p-8 rounded-3xl border border-slate-700/50 hover:border-[rgb(var(--color-primary))]/40 transition-all duration-400 hover:-translate-y-1 hover:shadow-2xl hover:shadow-[rgb(var(--color-primary))]/5"
          data-animate
          data-animate-delay={String(i * 100)}
        >
          <!-- Quote mark -->
          <div class="absolute top-6 right-7 text-6xl font-serif leading-none select-none opacity-10" style="color: rgb(var(--color-primary))">&rdquo;</div>

          <!-- Stars -->
          <div class="flex gap-1 mb-6">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Comment -->
          <p class="text-slate-300 leading-relaxed italic mb-8 relative z-10">
            "{t.comment}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-4 pt-6 border-t border-slate-700/50">
            <div class={`w-12 h-12 rounded-full flex items-center justify-center text-white font-bold text-lg shadow-lg bg-gradient-to-br ${colors[i % colors.length]}`}>
              {t.name.charAt(0)}
            </div>
            <div>
              <p class="font-bold text-white">{t.name}</p>
              <p class="text-sm font-medium" style="color: rgb(var(--color-primary))">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
