---
interface Props {
  whatsapp: string;
  message?: string;
}

const { whatsapp, message = 'Merhaba, bilgi almak istiyorum.' } = Astro.props;
const waNumber = whatsapp.replace(/[^0-9]/g, '');
const waUrl = `https://wa.me/${waNumber}?text=${encodeURIComponent(message)}`;
---

<a
  href={waUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="wa-float"
  aria-label="WhatsApp ile iletişime geçin"
  title="WhatsApp'tan yazın"
>
  <span class="wa-ring"></span>
  <div
    class="relative w-16 h-16 rounded-full flex items-center justify-center shadow-2xl transition-transform duration-300 hover:scale-110"
    style="background: #25D366"
  >
    <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 448 512">
      <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l121.7-31.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6z"/>
    </svg>
  </div>
</a>
