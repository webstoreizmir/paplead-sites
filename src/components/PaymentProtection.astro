---
import siteConfig from '../data/site-config.json';

const isPaid = (siteConfig as any).is_paid ?? false;

if (isPaid) {
  return null;
}
---

<div id="demo-banner" class="fixed bottom-0 left-0 w-full z-[9999] shadow-2xl">
  <div class="bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900 border-t-2 border-red-500 px-6 py-3 flex items-center justify-between gap-4 flex-wrap">
    <div class="flex items-center gap-3">
      <div class="w-2 h-2 rounded-full bg-red-500 animate-pulse flex-shrink-0"></div>
      <p class="text-sm font-semibold text-white">
        Demo Sürümü — Bu site henüz yayında değil.
      </p>
    </div>
    <a
      href="#contact"
      class="bg-red-500 hover:bg-red-600 text-white text-sm font-bold px-5 py-2 rounded-lg transition-colors duration-200 flex-shrink-0"
    >
      Aktifleştir
    </a>
  </div>
</div>
