---
import { getUI } from '../utils/i18n';
import { getSmartImage } from '../utils/images';

interface Props {
  headline: string;
  subheadline: string;
  ctaButtonText: string;
  imageKeyword: string;
  badgeText?: string;
  stats?: { value: string; label: string }[];
  whatsapp?: string;
}

const { headline, subheadline, ctaButtonText, imageKeyword, badgeText, stats, whatsapp, locale } = Astro.props;
const ui = getUI(locale);
const bgImage = getSmartImage(imageKeyword);
const waNumber = whatsapp ? whatsapp.replace(/[^0-9]/g, '') : '';
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img
      src={bgImage}
      alt="Hero Background"
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <!-- Layered Overlays -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-950/85 via-slate-900/70 to-slate-950/80"></div>
    <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(2,6,23,0.95) 0%, transparent 60%)"></div>
  </div>

  <!-- Decorative Blobs -->
  <div class="absolute top-20 right-10 w-72 h-72 rounded-full blur-3xl opacity-20 animate-float-slow pointer-events-none" style="background: rgb(var(--color-primary))"></div>
  <div class="absolute bottom-32 left-10 w-56 h-56 rounded-full blur-3xl opacity-15 animate-float pointer-events-none" style="background: rgb(var(--color-secondary)); animation-delay: 2s;"></div>
  <div class="absolute top-1/2 left-1/2 w-96 h-96 rounded-full blur-3xl opacity-5 -translate-x-1/2 -translate-y-1/2 pointer-events-none animate-spin-slow" style="background: conic-gradient(rgb(var(--color-primary)), rgb(var(--color-secondary)), rgb(var(--color-primary)))"></div>

  <!-- Content -->
  <div class="container mx-auto px-6 relative z-10 pt-28 pb-20 text-center">
    <div class="max-w-5xl mx-auto">

      {badgeText && (
        <div class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full border border-white/20 text-white text-sm font-semibold mb-8 backdrop-blur-md bg-white/10 shadow-lg">
          <span class="w-2 h-2 rounded-full animate-pulse" style="background: rgb(var(--color-primary))"></span>
          {badgeText}
        </div>
      )}

      <h1 class="text-5xl md:text-7xl lg:text-8xl font-heading font-bold mb-8 text-white leading-[1.08] text-shadow">
        {headline}
      </h1>

      <p class="text-xl md:text-2xl text-slate-300 mb-12 font-body max-w-3xl mx-auto leading-relaxed">
        {subheadline}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href="#contact"
          class="group relative px-9 py-4 text-lg font-bold text-white rounded-full shadow-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
          style="background: linear-gradient(135deg, rgb(var(--color-primary)), rgb(var(--color-secondary)))"
        >
          <span class="relative z-10">{ctaButtonText}</span>
          <div class="absolute inset-0 bg-white/0 group-hover:bg-white/10 transition-colors duration-300"></div>
        </a>

        {waNumber && (
          <a
            href={`https://wa.me/${waNumber}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 px-8 py-4 text-lg font-semibold text-white rounded-full bg-white/10 border border-white/20 hover:bg-white/20 backdrop-blur-md transition-all duration-300 hover:-translate-y-1"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 448 512">
              <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l121.7-31.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6z"/>
            </svg>
            WhatsApp'tan Yaz
          </a>
        )}

        {!waNumber && (
          <a
            href="#about"
            class="px-8 py-4 text-lg font-semibold text-white rounded-full bg-white/10 border border-white/20 hover:bg-white/20 backdrop-blur-md transition-all duration-300 hover:-translate-y-1"
          >
            Daha Fazla Bilgi
          </a>
        )}
      </div>

      {stats && stats.length > 0 && (
        <div class="mt-20 grid grid-cols-2 md:grid-cols-3 gap-4 max-w-2xl mx-auto">
          {stats.map((stat) => (
            <div class="glass rounded-2xl px-6 py-5 text-center">
              <p class="text-3xl font-bold text-white mb-1" style="color: rgb(var(--color-primary))">{stat.value}</p>
              <p class="text-xs text-slate-400 font-medium uppercase tracking-wider">{stat.label}</p>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 animate-bounce">
    <span class="text-xs text-white/50 font-medium tracking-widest uppercase">{ui.hero.scroll}</span>
    <svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
