---
interface ContactInfo {
  address: string;
  phone: string;
  email: string;
  whatsapp?: string;
  instagram?: string;
  linkedin?: string;
}

interface Props {
  title: string;
  description: string;
  contact: ContactInfo;
}

const { title, description, contact } = Astro.props;
const currentYear = new Date().getFullYear();
const shortDesc = description.length > 160 ? description.substring(0, 157) + '...' : description;
const hasSocials = contact.instagram || contact.linkedin || contact.whatsapp;
---

<footer class="relative bg-slate-950 text-white overflow-hidden">
  <!-- Top gradient accent -->
  <div class="h-px w-full bg-primary-gradient opacity-40"></div>
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-96 h-96 rounded-full blur-3xl opacity-[0.04] pointer-events-none" style="background: rgb(var(--color-primary))"></div>

  <div class="container-custom pt-20 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">

      <!-- Brand -->
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center font-bold text-xl shadow-lg bg-primary-gradient">
            {title.charAt(0).toUpperCase()}
          </div>
          <span class="text-2xl font-bold font-heading tracking-tight">{title}</span>
        </div>
        <p class="text-slate-400 max-w-sm leading-relaxed text-sm mb-8">{shortDesc}</p>

        <!-- Contact details -->
        <div class="space-y-3 text-sm text-slate-400">
          {contact.address && (
            <div class="flex items-start gap-3">
              <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: rgb(var(--color-primary))" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span>{contact.address}</span>
            </div>
          )}
          {contact.email && (
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 flex-shrink-0" style="color: rgb(var(--color-primary))" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <a href={`mailto:${contact.email}`} class="hover:text-white transition-colors">{contact.email}</a>
            </div>
          )}
          {contact.phone && (
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 flex-shrink-0" style="color: rgb(var(--color-primary))" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <a href={`tel:${contact.phone}`} class="hover:text-white transition-colors">{contact.phone}</a>
            </div>
          )}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-sm font-bold mb-6 text-white uppercase tracking-wider">Menü</h4>
        <ul class="space-y-3 text-sm">
          <li><a href="#hero"         class="text-slate-400 hover:text-white hover:translate-x-1 transition-all inline-block">Ana Sayfa</a></li>
          <li><a href="#about"        class="text-slate-400 hover:text-white hover:translate-x-1 transition-all inline-block">Hakkımızda</a></li>
          <li><a href="#services"     class="text-slate-400 hover:text-white hover:translate-x-1 transition-all inline-block">Hizmetler</a></li>
          <li><a href="#process"      class="text-slate-400 hover:text-white hover:translate-x-1 transition-all inline-block">Nasıl Çalışır</a></li>
          <li><a href="#testimonials" class="text-slate-400 hover:text-white hover:translate-x-1 transition-all inline-block">Referanslar</a></li>
          <li><a href="#contact"      class="text-slate-400 hover:text-white hover:translate-x-1 transition-all inline-block">İletişim</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-bold mb-6 text-white uppercase tracking-wider">Kurumsal</h4>
        <ul class="space-y-3 text-sm">
          <li><a href="#" class="text-slate-400 hover:text-white hover:translate-x-1 transition-all inline-block">Gizlilik Politikası</a></li>
          <li><a href="#" class="text-slate-400 hover:text-white hover:translate-x-1 transition-all inline-block">Kullanım Şartları</a></li>
          <li><a href="#" class="text-slate-400 hover:text-white hover:translate-x-1 transition-all inline-block">KVKK Metni</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-slate-800/80 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-slate-500 text-sm">
        &copy; {currentYear} {title}. Tüm hakları saklıdır.
        <span class="ml-2 text-slate-600">·</span>
        <a href="https://paplead.com" target="_blank" rel="noopener noreferrer" class="ml-2 text-slate-600 hover:text-purple-400 transition-colors" style="font-size:0.75rem;">paplead.com ile oluşturuldu</a>
      </p>

      {hasSocials && (
        <div class="flex gap-3">
          {contact.instagram && (
            <a href={contact.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
              class="w-10 h-10 rounded-xl bg-slate-800 flex items-center justify-center text-slate-400 hover:bg-[rgb(var(--color-primary))] hover:text-white transition-all border border-slate-700 hover:border-transparent">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          )}
          {contact.linkedin && (
            <a href={contact.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
              class="w-10 h-10 rounded-xl bg-slate-800 flex items-center justify-center text-slate-400 hover:bg-[rgb(var(--color-primary))] hover:text-white transition-all border border-slate-700 hover:border-transparent">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </a>
          )}
          {contact.whatsapp && (
            <a href={`https://wa.me/${contact.whatsapp.replace(/[^0-9]/g, '')}`} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp"
              class="w-10 h-10 rounded-xl bg-slate-800 flex items-center justify-center text-slate-400 hover:bg-green-600 hover:text-white transition-all border border-slate-700 hover:border-transparent">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 448 512"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l121.7-31.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6z"/></svg>
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</footer>
