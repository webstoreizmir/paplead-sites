---
interface ContactInfo {
  address: string;
  phone: string;
  email: string;
  map_query: string;
  whatsapp?: string;
  instagram?: string;
  linkedin?: string;
}

interface Props {
  contact: ContactInfo;
}

const { contact } = Astro.props;
const waNumber = contact.whatsapp ? contact.whatsapp.replace(/[^0-9]/g, '') : '';
---

<section id="contact" class="py-28 bg-white relative overflow-hidden">
  <div class="absolute bottom-0 left-0 w-72 h-72 rounded-full blur-3xl opacity-5 pointer-events-none" style="background: rgb(var(--color-secondary))"></div>

  <div class="container-custom">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16" data-animate>
      <span class="section-label">İletişim</span>
      <h2 class="section-title mb-5">Hadi Konuşalım</h2>
      <p class="section-subtitle">Projeniz için en iyi çözümü birlikte belirleyelim.</p>
    </div>

    <!-- Main Card -->
    <div class="bg-slate-50 rounded-[2.5rem] shadow-xl overflow-hidden border border-slate-100" data-animate>
      <div class="flex flex-col lg:flex-row min-h-[600px]">

        <!-- Info Side -->
        <div class="w-full lg:w-5/12 p-10 lg:p-14 text-white relative overflow-hidden flex flex-col justify-between bg-primary-gradient">
          <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
          <div class="absolute -bottom-10 -right-10 w-48 h-48 rounded-full bg-white/5"></div>

          <div class="relative z-10">
            <h3 class="text-2xl md:text-3xl font-bold mb-4">İletişime Geçin</h3>
            <p class="text-white/80 mb-10 leading-relaxed">
              Projelerinizi hayata geçirmek için sabırsızlanıyoruz. Hemen bize ulaşın.
            </p>

            <div class="space-y-6">
              {contact.address && (
                <div class="flex items-start gap-4">
                  <div class="w-11 h-11 rounded-xl bg-white/15 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  </div>
                  <div>
                    <p class="text-white/60 text-xs font-semibold uppercase tracking-wide mb-1">Adres</p>
                    <p class="font-medium">{contact.address}</p>
                  </div>
                </div>
              )}

              {contact.phone && (
                <a href={`tel:${contact.phone}`} class="flex items-start gap-4 hover:translate-x-1 transition-transform group">
                  <div class="w-11 h-11 rounded-xl bg-white/15 flex items-center justify-center flex-shrink-0 group-hover:bg-white/25 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  </div>
                  <div>
                    <p class="text-white/60 text-xs font-semibold uppercase tracking-wide mb-1">Telefon</p>
                    <p class="font-medium">{contact.phone}</p>
                  </div>
                </a>
              )}

              {contact.email && (
                <a href={`mailto:${contact.email}`} class="flex items-start gap-4 hover:translate-x-1 transition-transform group">
                  <div class="w-11 h-11 rounded-xl bg-white/15 flex items-center justify-center flex-shrink-0 group-hover:bg-white/25 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  </div>
                  <div>
                    <p class="text-white/60 text-xs font-semibold uppercase tracking-wide mb-1">E-posta</p>
                    <p class="font-medium">{contact.email}</p>
                  </div>
                </a>
              )}
            </div>
          </div>

          {waNumber && (
            <div class="relative z-10 mt-10">
              <a
                href={`https://wa.me/${waNumber}`}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-3 w-full py-4 px-6 rounded-2xl bg-white/20 hover:bg-white/30 transition-all duration-300 font-bold text-white border border-white/30 hover:border-white/50 hover:-translate-y-0.5"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 448 512">
                  <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l121.7-31.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6z"/>
                </svg>
                WhatsApp ile Yaz
              </a>
            </div>
          )}
        </div>

        <!-- Form Side -->
        <div class="w-full lg:w-7/12 bg-white p-10 lg:p-14">
          <h4 class="text-2xl font-bold text-slate-900 mb-8">Mesaj Gönderin</h4>
          <form class="space-y-5" id="contact-form">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label class="block text-xs font-bold text-slate-500 mb-2 uppercase tracking-wider">Adınız</label>
                <input type="text" class="input-field" placeholder="Adınız Soyadınız" required />
              </div>
              <div>
                <label class="block text-xs font-bold text-slate-500 mb-2 uppercase tracking-wider">Telefon</label>
                <input type="tel" class="input-field" placeholder="05xx xxx xxxx" />
              </div>
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-500 mb-2 uppercase tracking-wider">E-posta</label>
              <input type="email" class="input-field" placeholder="ornek@sirket.com" required />
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-500 mb-2 uppercase tracking-wider">Mesajınız</label>
              <textarea rows="4" class="input-field resize-none" placeholder="Size nasıl yardımcı olabiliriz?"></textarea>
            </div>
            <button
              type="submit"
              class="btn-primary w-full text-base gap-2"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
              Mesajı Gönder
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Map -->
    {contact.map_query && (
      <div class="mt-12 rounded-3xl overflow-hidden shadow-lg border border-slate-200 h-[380px]" data-animate>
        <iframe
          width="100%"
          height="100%"
          frameborder="0"
          style="border:0; filter: saturate(0.7) contrast(1.1);"
          src={`https://maps.google.com/maps?q=${encodeURIComponent(contact.map_query)}&t=&z=14&ie=UTF8&iwloc=&output=embed`}
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    )}
  </div>
</section>
